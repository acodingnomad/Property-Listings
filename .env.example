# Apify token (apify.com -> Settings -> Integrations -> API tokens)
APIFY_TOKEN=

# Google service account JSON (entire file contents, on one line)
GOOGLE_SA_KEY=

# Google Sheet ID (from URL: docs.google.com/spreadsheets/d/<ID>/edit)
SHEET_ID=

# Search criteria live in config.json (committed). Edit there to tune
# locations, price range, beds, baths, sqft, and lot size per tab (LA / BK).
